# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/

# Virtual environments (never commit)
venv/
.venv/
env/

# --- Local state / data (JSON) ---
*.json

# --- SQLite and similar DB files ---
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# --- App thumbnails / cache ---
thumbnail_cache/
bookmarks/

# Tag engine cache (large binaries, generated locally)
app/tag_engine/cache_*.pkl

# --- FFmpeg / external binaries (user-provided in tools/) ---
tools/

# --- AI Weights (YOLO, ONNX, etc. — user must download to app/models/) ---
app/models/**/*.pt
app/models/**/*.pth
app/models/**/*.onnx
app/models/**/*.engine
app/models/**/*.safetensors
app/models/**/*.ckpt

# --- Logs and debug outputs ---
*.log
*.log.*
vlc-log.txt
install_log.txt
startup_errors.txt
trace start.txt
update.txt

# Local debug launcher (optional — keep out of git)
run_debug.bat

# cProfile outputs stay out of repository (profiling .bat files save to profiling/)
# — already covered by global *.prof below

# --- Tests / Tools ---
.pytest_cache/
.mypy_cache/
htmlcov/
.coverage
coverage.xml
*.prof
profiling/*_tottime.txt
profiling/*_cumtime.txt

# --- Local system / associations (Windows) ---
*.reg

# --- IDE / OS ---
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
Desktop.ini

# --- Optional local notes ---
update.txt
backup.py

# --- Secrets (recommended) ---
.env
.env.*

# --- Vibe Player Specific Files (Cleanup) ---
# Profiling outputs and debug logs
app/*_cprofile.txt
app/profile_paths_*.txt
app/run_profiling.py

# Redundant requirements (main file is in root)
app/requirements.txt

# The accidental 'git' file in root
/git